{
  "name": "@kt-virtual-env/desktop",
  "version": "0.1.19",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "pack:mac": "pnpm build && electron-builder --mac --config electron-builder.config.cjs --publish never",
    "pack:mac:arm64": "pnpm build && electron-builder --mac --arm64 --config electron-builder.config.cjs --publish never",
    "pack:mac:x64": "pnpm build && electron-builder --mac --x64 --config electron-builder.config.cjs --publish never",
    "pack:win": "pnpm build && electron-builder --win --config electron-builder.config.cjs --publish never",
    "publish:github": "electron-builder --config electron-builder.config.cjs --publish always"
  },
  "dependencies": {
    "@kt-virtual-env/k8s-discovery": "workspace:*",
    "@kt-virtual-env/shared": "workspace:*",
    "adm-zip": "^0.5.17",
    "electron-updater": "^6.8.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.4.0",
    "vite": "^5.4.11",
    "vitest": "^2.1.0"
  },
  "build": {
    "extends": "electron-builder.yml"
  }
}
